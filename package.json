{
  "name": "@calltelemetry/cisco-axl-mcp",
  "version": "0.5.0",
  "description": "MCP server for Cisco CUCM AXL (SOAP) via cisco-axl",
  "type": "module",
  "main": "build/index.js",
  "bin": "build/index.js",
  "files": [
    "build/**/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate:types": "tsx scripts/generate-types.ts",
    "print:objects": "node -e \"const fs=require('fs'); console.log(fs.readFileSync('generated/axl-top-level-objects.json','utf8'))\"",
    "build": "vite build && chmod +x build/index.js",
    "start": "node build/index.js",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ test/ scripts/",
    "lint:fix": "eslint src/ test/ scripts/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' 'scripts/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts' 'scripts/**/*.ts'",
    "test": "vitest run",
    "test:mcp": "vitest run test/mcp-conformance.test.ts",
    "validate": "yarn typecheck && yarn lint --max-warnings=50 && yarn test",
    "prepack": "yarn build && yarn test:mcp"
  },
  "keywords": [
    "mcp",
    "cisco",
    "cucm",
    "axl",
    "soap"
  ],
  "author": "CallTelemetry",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.6.0",
    "cisco-axl": "^2.1.0",
    "dotenv": "^17.4.2",
    "strong-soap": "^4.1.14",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "packageManager": "yarn@4.12.0"
}
